# AI Job Hunter — 环境变量配置
# 复制此文件为 .env 后修改

# ===== 必填 =====
# Anthropic API Key (申请地址: https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ===== 数据库 =====
# SQLite (默认，无需额外配置)
DATABASE_URL=sqlite+aiosqlite:///./aijob.db
# PostgreSQL 生产环境:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/aijob

# ===== JWT =====
# 生产环境务必更换为随机字符串 (生成: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Redis (Celery 消息队列，可选) =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== 邮件 (可选，不配置则 log 到控制台) =====
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=password
# SMTP_FROM=noreply@aijobhunter.local

# ===== 调试 =====
# DEBUG=true
